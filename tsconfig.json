{
  "compilerOptions": {
    "noEmit": true,
    "target": "es6",
    "module": "esnext",
    "noImplicitAny": false,
    "preserveConstEnums": true,
    "jsx": "react",
    "lib": [
      "dom",
      "es5",
      "es6",
      "es7",
      "es2017"
    ],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "allowJs": true,
    "skipLibCheck": true,
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": false,
    "strict": true,
    "strictFunctionTypes": false,
    "pretty": true,
    "removeComments": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "baseUrl": "src",
    "paths": {
      "app": ["app/index"],
      "app/*": ["app/*"],
      "shared": ["shared/index"],
      "shared/*": ["shared/*"],
      "features": ["features/index"],
      "features/*": ["features/*"],
      "components": ["shared/components/index"],
      "components/*": ["shared/components/*"],
      "utils": ["shared/utils/index"],
      "utils/*": ["shared/utils/*"],
      "service": ["shared/services/index"],
      "service/*": ["shared/services/*"],
      "hooks": ["shared/hooks/index"],
      "hooks/*": ["shared/hooks/*"],
      "state": ["app/state/index"],
      "state/*": ["app/state/*"],
      "static": ["shared/assets/index"],
      "static/*": ["shared/assets/*"],
      "css": ["app/css/index"],
      "css/*": ["app/css/*"],
      "models": ["shared/types/index"],
      "models/*": ["shared/types/*"],
      "data": ["shared/data/index"],
      "data/*": ["shared/data/*"],
      "constants": ["shared/constants/index"],
      "constants/*": ["shared/constants/*"],
      "types": ["shared/types/index"],
      "types/*": ["shared/types/*"]
    },
    "types": ["node", "vite/client"]
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "src",
    "vite.config.ts",
    "api.config.ts"
  ]
}