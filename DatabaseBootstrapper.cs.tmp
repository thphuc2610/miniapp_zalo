using System.Data;
namespace BETamNhatSpa.Services.Core;
public static class DatabaseBootstrapper
{
    public static void EnsureCreated(IDatabaseService database)
    {
        RunSafe(database, "CREATE EXTENSION IF NOT EXISTS pgcrypto;");
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.branches (
            id uuid PRIMARY KEY,
            name varchar(255) NOT NULL,
            address varchar(500),
            phone varchar(30),
            email varchar(100),
            image_url varchar(500),
            latitude numeric(10, 8),
            longitude numeric(11, 8),
            status varchar(30) NOT NULL DEFAULT 'active',
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.roles (
            id uuid PRIMARY KEY,
            name varchar(100) NOT NULL UNIQUE,
            description varchar(500),
            status varchar(30) NOT NULL DEFAULT 'active',
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.permissions (
            id uuid PRIMARY KEY,
            module_name varchar(100) NOT NULL,
            action_name varchar(100) NOT NULL,
            name varchar(255) NOT NULL,
            description varchar(500),
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz,
            CONSTRAINT ux_permissions_module_action UNIQUE (module_name, action_name)
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.role_permissions (
            id uuid PRIMARY KEY,
            role_id uuid NOT NULL REFERENCES public.roles(id) ON DELETE CASCADE,
            permission_id uuid NOT NULL REFERENCES public.permissions(id) ON DELETE CASCADE,
            created_at timestamptz NOT NULL DEFAULT now(),
            CONSTRAINT ux_role_permissions UNIQUE (role_id, permission_id)
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.users (
            id uuid PRIMARY KEY,
            email varchar(255) NOT NULL UNIQUE,
            full_name varchar(255) NOT NULL,
            avatar_url varchar(500),
            role_id uuid REFERENCES public.roles(id) ON DELETE SET NULL,
            password_hash varchar(500) NOT NULL,
            password_salt varchar(500) NOT NULL,
            status varchar(30) NOT NULL DEFAULT 'active',
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, "ALTER TABLE public.users ADD COLUMN IF NOT EXISTS phone varchar(30);");
        RunSafe(database, "ALTER TABLE public.users ADD CONSTRAINT ux_users_phone UNIQUE (phone);");
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.users_branches (
            id uuid PRIMARY KEY,
            user_id uuid NOT NULL REFERENCES public.users(id) ON DELETE CASCADE,
            branch_id uuid NOT NULL REFERENCES public.branches(id) ON DELETE CASCADE,
            created_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz,
            CONSTRAINT ux_users_branches UNIQUE (user_id, branch_id)
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.customers (
            id uuid PRIMARY KEY,
            full_name varchar(255) NOT NULL,
            avatar_url varchar(500),
            phone varchar(30) NOT NULL UNIQUE,
            email varchar(255),
            date_of_birth date,
            gender varchar(20),
            default_branch_id uuid REFERENCES public.branches(id) ON DELETE SET NULL,
            zalo_id varchar(100),
            source varchar(50),
            status varchar(30) NOT NULL DEFAULT 'active',
            tags text[],
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.service_categories (
            id uuid PRIMARY KEY,
            name varchar(100) NOT NULL,
            description varchar(500),
            sort_order integer,
            status varchar(30) NOT NULL DEFAULT 'active',
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.services (
            id uuid PRIMARY KEY,
            name varchar(255) NOT NULL,
            category_name varchar(100),
            description text,
            duration_minutes integer NOT NULL,
            price numeric(18, 2) NOT NULL,
            image_url varchar(500),
            status varchar(30) NOT NULL DEFAULT 'active',
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, "ALTER TABLE public.services ADD COLUMN IF NOT EXISTS is_featured boolean DEFAULT false;");
        RunSafe(database, "UPDATE public.amenities SET is_active = true WHERE is_active IS NULL;");
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.treatment_packages (
            id uuid PRIMARY KEY,
            name varchar(255) NOT NULL,
            category_name varchar(100),
            session_count integer,
            price numeric(18, 2),
            validity_days integer,
            included_services text,
            description text,
            status varchar(30) NOT NULL DEFAULT 'active',
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.service_combos (
            id uuid PRIMARY KEY,
            name varchar(255) NOT NULL,
            included_services text,
            original_price numeric(18, 2),
            combo_price numeric(18, 2),
            usage_limit integer,
            valid_from timestamptz,
            valid_to timestamptz,
            description text,
            status varchar(30) NOT NULL DEFAULT 'active',
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.vouchers (
            id uuid PRIMARY KEY,
            code varchar(50) NOT NULL UNIQUE,
            name varchar(255) NOT NULL,
            description text,
            discount_type varchar(20) NOT NULL,
            discount_value numeric(18, 2) NOT NULL,
            min_order_value numeric(18, 2),
            max_discount_value numeric(18, 2),
            valid_from timestamptz NOT NULL,
            valid_to timestamptz NOT NULL,
            usage_limit integer,
            used_count integer NOT NULL DEFAULT 0,
            image_url varchar(500),
            status varchar(30) NOT NULL DEFAULT 'active',
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.bookings (
            id uuid PRIMARY KEY,
            customer_id uuid NOT NULL REFERENCES public.customers(id) ON DELETE CASCADE,
            branch_id uuid NOT NULL REFERENCES public.branches(id) ON DELETE RESTRICT,
            scheduled_start timestamptz NOT NULL,
            scheduled_end timestamptz NOT NULL,
            status varchar(30) NOT NULL DEFAULT 'pending',
            source varchar(50) NOT NULL DEFAULT 'manual',
            note text,
            check_in_at timestamptz,
            started_at timestamptz,
            check_out_at timestamptz,
            total_price numeric(18, 2),
            voucher_code varchar(50),
            technician_id uuid REFERENCES public.users(id) ON DELETE SET NULL,
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, "ALTER TABLE public.bookings ADD COLUMN IF NOT EXISTS technician_id uuid REFERENCES public.users(id) ON DELETE SET NULL;");
        RunSafe(database, "ALTER TABLE public.bookings ADD COLUMN IF NOT EXISTS total_price numeric(18, 2);");
        RunSafe(database, "ALTER TABLE public.bookings ADD COLUMN IF NOT EXISTS voucher_code varchar(50);");

        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.booking_services (
            id uuid PRIMARY KEY,
            booking_id uuid NOT NULL REFERENCES public.bookings(id) ON DELETE CASCADE,
            service_id uuid NOT NULL REFERENCES public.services(id) ON DELETE RESTRICT,
            price_at_booking numeric(18, 2) NOT NULL,
            duration_minutes integer NOT NULL,
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz,
            CONSTRAINT ux_booking_services_booking_service UNIQUE (booking_id, service_id)
        );
        """);
        // Action Request: Clear all booking data
        RunSafe(database, "DELETE FROM public.booking_services;");
        RunSafe(database, "DELETE FROM public.bookings;");
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.membership_tiers (
            id uuid PRIMARY KEY,
            name varchar(100) NOT NULL UNIQUE,
            description text,
            min_spend numeric(18, 2) NOT NULL,
            discount_percentage integer NOT NULL,
            status varchar(30) NOT NULL DEFAULT 'active',
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, "ALTER TABLE public.membership_tiers ADD COLUMN IF NOT EXISTS sort_order integer DEFAULT 0;");
        RunSafe(database, "ALTER TABLE public.membership_tiers ADD COLUMN IF NOT EXISTS default_discount_percent numeric(5, 2) DEFAULT 0;");
        RunSafe(database, "ALTER TABLE public.membership_tiers ADD COLUMN IF NOT EXISTS reward_rate_percent numeric(5, 2) DEFAULT 0;");
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.membership_plans (
            id uuid PRIMARY KEY,
            tier_id uuid NOT NULL REFERENCES public.membership_tiers(id) ON DELETE CASCADE,
            name varchar(100) NOT NULL,
            price numeric(18, 2) NOT NULL,
            validity_days integer NOT NULL,
            benefits text,
            status varchar(30) NOT NULL DEFAULT 'active',
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.reviews (
            id uuid PRIMARY KEY,
            customer_id uuid REFERENCES public.customers(id) ON DELETE SET NULL,
            customer_name varchar(255),
            customer_avatar varchar(500),
            rating integer NOT NULL CHECK (rating >= 1 AND rating <= 5),
            comment text,
            status varchar(30) NOT NULL DEFAULT 'pending',
            admin_note text,
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, "ALTER TABLE public.reviews ADD COLUMN IF NOT EXISTS service_name varchar(255);");
        RunSafe(database, "ALTER TABLE public.reviews ADD COLUMN IF NOT EXISTS content text;");
        RunSafe(database, "ALTER TABLE public.reviews ADD COLUMN IF NOT EXISTS moderation_note text;");
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.banners (
            id uuid PRIMARY KEY,
            title varchar(255),
            image_url varchar(500) NOT NULL,
            link_url varchar(500),
            sort_order integer NOT NULL DEFAULT 0,
            is_active boolean NOT NULL DEFAULT true,
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.article_categories (
            id uuid PRIMARY KEY,
            name varchar(100) NOT NULL,
            description varchar(500),
            sort_order integer NOT NULL DEFAULT 0,
            status varchar(30) NOT NULL DEFAULT 'active',
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, "ALTER TABLE public.article_categories ADD COLUMN IF NOT EXISTS status varchar(30) DEFAULT 'active';");
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.articles (
            id uuid PRIMARY KEY,
            category_id uuid REFERENCES public.article_categories(id) ON DELETE SET NULL,
            title varchar(255) NOT NULL,
            summary text,
            content_html text,
            thumbnail_url varchar(500),
            author_name varchar(100),
            tags varchar(500),
            view_count integer NOT NULL DEFAULT 0,
            is_featured boolean NOT NULL DEFAULT false,
            status varchar(30) NOT NULL DEFAULT 'draft',
            published_at timestamptz,
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.treatment_history (
            id uuid PRIMARY KEY,
            customer_id uuid NOT NULL REFERENCES public.customers(id) ON DELETE CASCADE,
            service_name varchar(255) NOT NULL,
            service_date date NOT NULL,
            session_number integer,
            staff_name varchar(255),
            rating integer,
            status varchar(30) DEFAULT 'completed',
            note text,
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.customer_care_tasks (
            id uuid PRIMARY KEY,
            customer_id uuid NOT NULL REFERENCES public.customers(id) ON DELETE CASCADE,
            reason varchar(500),
            care_date date NOT NULL,
            assignee_name varchar(255),
            status varchar(30) DEFAULT 'open',
            result text,
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.amenities (
            id uuid PRIMARY KEY,
            code varchar(50),
            name varchar(100) NOT NULL,
            description varchar(500),
            icon_url varchar(500),
            link varchar(500),
            sort_order integer NOT NULL DEFAULT 0,
            is_active boolean NOT NULL DEFAULT true,
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now(),
            deleted_at timestamptz
        );
        """);
        RunSafe(database, """
        CREATE TABLE IF NOT EXISTS public.spa_settings (
            id uuid PRIMARY KEY,
            brand_name varchar(255) NOT NULL,
            logo_url varchar(500),
            intro_html text,
            address varchar(500),
            phone varchar(30),
            email varchar(100),
            working_hours varchar(200),
            facebook varchar(500),
            zalo varchar(500),
            youtube varchar(500),
            show_logo_sidebar boolean NOT NULL DEFAULT true,
            created_at timestamptz NOT NULL DEFAULT now(),
            updated_at timestamptz NOT NULL DEFAULT now()
        );
        """);
    }
    private static void RunSafe(IDatabaseService database, string sql)
    {
        try
        {
            database.RunQuery(sql);
        }
        catch (Exception exception)
        {
            Console.WriteLine("Bá» qua lá»‡nh bootstrap database chÆ°a cháº¡y Ä‘Æ°á»£c: " + exception.Message);
        }
    }
}
